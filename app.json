{
  "expo": {
    "name": "Oestra",
    "slug": "oestra",
    "scheme": "oestra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FAF7F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oestra.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Oestra uses your health data to provide personalized cycle and hormone insights.",
        "NSHealthUpdateUsageDescription": "Oestra saves your cycle and symptom data to Apple Health."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF7F2"
      },
      "package": "com.oestra.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ]
  }
}
